<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>

        <HBox alignment="CENTER" prefHeight="370.0" prefWidth="968.0" spacing="30" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="-8.0" AnchorPane.topAnchor="0.0">

            <padding>
                <Insets bottom="60" left="60" right="60" top="60" />
            </padding>

            <!-- FAST PASS -->
            <VBox alignment="CENTER" prefWidth="260" spacing="15" stylesheets="@css/escogerPlan.css">

                <Label style="-fx-background-color:#1abc9c; -fx-text-fill:white; -fx-padding:5 12; -fx-background-radius:20;" text="Más popular" />

                <Label styleClass="title" text="Fast-Pass" />
                <Label styleClass="price" text="\$69.990" />

                <VBox alignment="CENTER" spacing="8">
                    <Label styleClass="item" text="✔ Acceso total" />
                    <Label styleClass="item" text="⚡ Prioridad en filas" />
                    <Label styleClass="item" text="🎟 Descuentos exclusivos" />
                </VBox>

                <Button maxWidth="Infinity" onAction="#comprarFastPass" styleClass="btn-solid" text="COMPRAR" />
            <styleClass>
               <String fx:value="card highlight" />
               <String fx:value="highlight" />
            </styleClass>
            </VBox>

            <!-- FAMILIAR -->
            <VBox alignment="CENTER" prefWidth="260" spacing="15" styleClass="card" stylesheets="@css/escogerPlan.css">

                <Label styleClass="title" text="Familiar" />
                <Label styleClass="price" text="\$49.990" />

                <VBox alignment="CENTER" spacing="8">
                    <Label styleClass="item" text="✔ Acceso total" />
                    <Label styleClass="item" text="🎟 Descuentos exclusivos" />
                </VBox>

                <Button maxWidth="Infinity" onAction="#comprarFamiliar" styleClass="btn-outline" text="COMPRAR" />
            </VBox>

            <!-- GENERAL -->
            <VBox alignment="CENTER" prefWidth="260" spacing="15" styleClass="card" stylesheets="@css/escogerPlan.css">

                <Label styleClass="title" text="General" />
                <Label styleClass="price" text="\$29.990" />

                <VBox alignment="CENTER" spacing="8">
                    <Label styleClass="item" text="✔ Acceso total" />
                </VBox>

                <Button maxWidth="Infinity" onAction="#comprarGeneral" styleClass="btn-outline" text="COMPRAR" />
            </VBox>

        </HBox>

    </children>
</AnchorPane>
